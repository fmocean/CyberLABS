<group name="local,sysmon,windows,linux,ssh,custom_rules,">

  <!-- Windows: PowerShell execution -->
  <rule id="100100" level="8">
    <if_group>windows,sysmon,</if_group>
    <field name="win.system.providerName">Microsoft-Windows-Sysmon</field>
    <field name="win.system.eventID">1</field>
    <match>powershell.exe</match>
    <description>Sysmon: PowerShell execution detected</description>
    <group>windows,powershell,sysmon,process_creation,</group>
  </rule>

  <!-- Windows: Encoded PowerShell -->
  <rule id="100101" level="12">
    <if_group>windows,sysmon,</if_group>
    <field name="win.system.providerName">Microsoft-Windows-Sysmon</field>
    <field name="win.system.eventID">1</field>
    <regex>-enc|-encodedcommand</regex>
    <description>Sysmon: Possible encoded PowerShell command detected</description>
    <group>windows,powershell,sysmon,encoded_command,</group>
  </rule>

  <!-- Windows: New local user added -->
  <rule id="100102" level="10">
    <if_group>windows,</if_group>
    <field name="win.system.eventID">4720</field>
    <description>Windows: New local user account created</description>
    <group>windows,user_management,account_creation,</group>
  </rule>

  <!-- Windows: User added to Administrators group -->
  <rule id="100103" level="12">
    <if_group>windows,</if_group>
    <field name="win.system.eventID">4732</field>
    <description>Windows: User added to privileged local group</description>
    <group>windows,privilege_escalation,user_management,</group>
  </rule>

  <!-- Linux: SSH authentication failure -->
  <rule id="100200" level="6">
    <match>Failed password</match>
    <description>Linux: SSH failed authentication attempt</description>
    <group>linux,ssh,authentication_failed,</group>
  </rule>

  <!-- Linux: Multiple SSH failures -->
  <rule id="100201" level="10" frequency="5" timeframe="60">
    <if_matched_sid>100200</if_matched_sid>
    <same_source_ip />
    <description>Linux: Multiple SSH authentication failures from same source</description>
    <group>linux,ssh,bruteforce,authentication_failed,</group>
  </rule>

  <!-- Linux: Sudo usage -->
  <rule id="100202" level="5">
    <match>sudo:</match>
    <description>Linux: Sudo command usage detected</description>
    <group>linux,sudo,privilege_use,</group>
  </rule>

  <!-- Generic: Wazuh agent disconnected -->
  <rule id="100300" level="7">
    <match>disconnected</match>
    <description>Wazuh: Agent disconnected or connection lost</description>
    <group>wazuh,agent,availability,</group>
  </rule>

</group>
